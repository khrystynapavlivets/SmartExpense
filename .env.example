# Local development (docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smartexpense
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartexpense
APP_ENV=development
SECRET_KEY=change-me-in-production
GROQ_API_KEY=your_groq_api_key_here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Kaggle dataset (optional, only for setup_dataset.py)
KAGGLE_API_TOKEN=your_kaggle_api_token_here

# =========================================
# [Render (Backend)] — set in Render dashboard
# =========================================
# DATABASE_URL   -> Supabase connection string, transaction pooler port 6543, e.g.
#                   postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
# APP_ENV        -> production
# SECRET_KEY     -> long random string (e.g. `openssl rand -hex 32`)
# GROQ_API_KEY   -> Groq API key
# ALLOWED_ORIGINS -> https://your-app.vercel.app (comma-separate multiple origins, no trailing slash)

# =========================================
# [Vercel (Frontend)] — set in Vercel dashboard
# =========================================
# VITE_API_URL   -> https://your-backend.onrender.com
